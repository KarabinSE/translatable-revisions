{
    "name": "karabin/translatable-revisions",
    "description": "Translatable revisions for Laravel",
    "type": "library",
    "require": {
        "php": "^7.3|^8.0",
        "illuminate/database": "^7.0|^8.40.0|^9.0|^10|^11|^12",
        "illuminate/support": "^7.0.5|^8.0|^9.0|^10|^11|^12"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^10.0",
        "nunomaduro/collision": "^8.1"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Albin Nilsson",
            "email": "albin@karabin.se"
        },
        {
            "name": "Daniel Källstrand Modig",
            "email": "daniel@ikoncept.se"
        }
    ],
    "autoload": {
        "psr-4": {
            "Karabin\\TranslatableRevisions\\": "src/",
            "Karabin\\TranslatableRevisions\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Karabin\\TranslatableRevisions\\Tests\\": "tests"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Karabin\\TranslatableRevisions\\TranslatableRevisionsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": [
            "php --version && php -d memory_limit=512M ./vendor/bin/phpstan analyse -c phpstan.neon",
            "php --version && vendor/bin/phpunit --coverage-text --testdox"
        ]
    }
}